# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Environments
.venv/
venv/
.env

# uv
# (uv.lock IS committed for reproducibility; do not ignore it)

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Project data and results (regenerated by scripts; not versioned)
# Ignore directory *contents* (with /*) so the .gitkeep can be re-included;
# a fully-ignored directory cannot re-include a child.
data/raw/*
data/processed/*
results/figures/*
results/tables/*
results/logs/*

# Keep the empty result/data dirs tracked via .gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/logs/.gitkeep

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Local harness/session artifacts
.claude/

# LaTeX build artifacts
*.aux
*.log
*.fls
*.fdb_latexmk
*.out
*.bbl
*.blg
*.synctex.gz
*.toc

# Generated report results (copies live under paper/)
results/report/
